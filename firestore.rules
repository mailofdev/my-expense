rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile document: users/{userId}
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcollection: users/{userId}/expenses/{expenseId}
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Subcollection: users/{userId}/walletTransactions/{txId}
      match /walletTransactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Everything else is denied by default (no catch-all needed)
  }
}
